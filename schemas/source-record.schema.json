{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cockroachcrawler.com/schemas/source-record.schema.json",
  "title": "Cockroach Crawler normalized source record",
  "description": "The provider-neutral record returned by Cockroach Crawler source adapters. The metadata object is intentionally provider-specific.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source",
    "id",
    "type",
    "title",
    "url",
    "text",
    "author",
    "publishedAt",
    "contentHash",
    "adapterVersion",
    "warnings",
    "metadata",
    "provenance"
  ],
  "properties": {
    "source": { "type": "string", "minLength": 1 },
    "id": { "type": "string", "minLength": 1 },
    "type": { "type": "string", "minLength": 1 },
    "title": { "type": "string" },
    "url": { "type": "string" },
    "text": { "type": "string" },
    "author": { "type": ["string", "null"] },
    "publishedAt": {
      "anyOf": [
        { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T" },
        { "type": "null" }
      ]
    },
    "contentHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "adapterVersion": { "type": "string", "minLength": 1 },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "metadata": {
      "type": "object",
      "description": "Provider-specific, JSON-serializable metadata. Consumers must not assume the same keys across providers.",
      "additionalProperties": true
    },
    "provenance": { "$ref": "#/$defs/provenance" }
  },
  "$defs": {
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["retrievedAt", "method", "authenticated", "credentialed"],
      "properties": {
        "retrievedAt": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T" },
        "method": { "type": "string", "minLength": 1 },
        "authenticated": { "type": "boolean" },
        "credentialed": { "type": "boolean" }
      }
    }
  }
}
