{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "cockroach-crawler-site",
  "main": "./site-worker.js",
  "compatibility_date": "2026-07-24",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": true,
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  }
}
